# GraphQL endpoint for schema introspection
# Default: http://localhost:8000/graphql/
GRAPHQL_ENDPOINT=http://localhost:8000/graphql/

# Skip Python type generation (optional)
# SKIP_PYTHON_GEN=true

# Skip TypeScript type generation (optional)
# SKIP_TS_GEN=true

# Custom output directories (optional)
# TS_OUTPUT_DIR=../typescript/src/generated
# PY_OUTPUT_DIR=../python/soroscan/generated
