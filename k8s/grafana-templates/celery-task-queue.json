{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "soroscan_celery_queue_depth",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Tasks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(soroscan_celery_tasks_active) by (task_name)",
          "legendFormat": "{{task_name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Completed and Failed Tasks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(soroscan_celery_tasks_total[5m])) by (status,task_name)",
          "legendFormat": "{{status}} {{task_name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Average Task Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(soroscan_celery_task_duration_seconds_sum[5m])) by (task_name) / clamp_min(sum(rate(soroscan_celery_task_duration_seconds_count[5m])) by (task_name), 0.001)",
          "legendFormat": "{{task_name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Workers Online",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 8 },
      "targets": [
        {
          "expr": "sum(soroscan_celery_workers_online)",
          "legendFormat": "workers"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["soroscan", "celery", "queue"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "SoroScan - Celery Task Queue",
  "uid": "soroscan-celery-queue",
  "version": 1
}
